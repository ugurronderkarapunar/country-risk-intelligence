# İsteğe bağlı: CORS (virgülle ayırın)
# CORS_ORIGINS=http://localhost:5173,https://yourdomain.com

# Zamanlanmış görevi kapatmak için (test)
# SCHEDULER_ENABLED=false

# ReliefWeb RSS (varsayılan aynı)
# RELIEFWEB_RSS_URL=https://reliefweb.int/updates/rss.xml

# Üretimde zorunlu: güçlü rastgele dize
# JWT_SECRET=...

# Demo: plan yükseltme (Starter→Pro) POST /api/org/demo-upgrade + header X-Demo-Upgrade-Secret
# DEMO_UPGRADE_SECRET=...
